{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/bedardandy/maine_mock_case_generator/catalog/mock_matter.schema.json",
  "title": "Mock Legal Matter",
  "description": "A rich, FICTIONAL legal matter used to smoke-test an end-to-end legal workflow pipeline (intake -> issue spotting -> form routing -> form filling). This is a superset of the downstream canonical fact object (catalog/canonical_case.schema.json): every Mock Matter can be projected to a canonical case via tools/project_canonical.py. All data is mock and fictional; it must never contain real personal information.",
  "type": "object",
  "required": ["schema_version", "provenance", "matter", "parties", "fact_pattern"],
  "additionalProperties": true,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0",
      "description": "Version of this Mock Matter schema."
    },
    "provenance": {
      "type": "object",
      "description": "Where this matter came from. Smoke-test fixtures are reproducible from (scenario_id, seed).",
      "required": ["mock", "fictional", "generator"],
      "additionalProperties": true,
      "properties": {
        "mock": { "const": true, "description": "Always true. Guards against confusing this with real matter data." },
        "fictional": { "const": true, "description": "Always true. All names, parties, and facts are invented." },
        "generator": { "type": "string", "description": "Producer, e.g. 'deterministic-engine' or 'agent-skill'." },
        "generator_version": { "type": "string" },
        "scenario_id": { "type": "string", "description": "Scenario archetype this matter was built from." },
        "seed": { "type": ["integer", "string", "null"], "description": "Seed for reproducible deterministic generation." },
        "model": { "type": ["string", "null"], "description": "Model id when generated by an LLM-guided path." },
        "created_utc": { "type": "string", "description": "ISO-8601 UTC timestamp." }
      }
    },
    "matter": {
      "type": "object",
      "description": "Top-level matter metadata. Projects to the downstream canonical `matter` object.",
      "required": ["matter_id", "practice_area", "jurisdiction"],
      "additionalProperties": true,
      "properties": {
        "matter_id": { "type": "string", "description": "Stable id for this matter, e.g. 'MMC-2026-000123'." },
        "practice_area": {
          "type": "string",
          "enum": ["family", "probate", "tax", "civil", "criminal", "business", "real_estate", "administrative", "other"]
        },
        "title": { "type": "string", "description": "Human-readable matter caption/title." },
        "jurisdiction": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "state": { "type": "string", "description": "USPS state code, e.g. 'ME'." },
            "county": { "type": "string" },
            "court_location": { "type": "string", "description": "Courthouse town/location." },
            "court_type": { "type": "string", "description": "e.g. 'District Court', 'Probate Court', 'Superior Court'." }
          }
        },
        "case_type": { "type": "string", "description": "Routing classification, e.g. 'family_matters', 'decedent_estate'." },
        "universe_id": { "type": "string", "description": "Set when this matter belongs to a compound matter universe (see related_matters)." },
        "docket_number": { "type": ["string", "null"] },
        "filing_date": { "type": ["string", "null"], "description": "ISO yyyy-mm-dd or null if unfiled." },
        "event_date": { "type": ["string", "null"], "description": "Key precipitating event date (ISO yyyy-mm-dd)." },
        "status": { "type": "string", "enum": ["intake", "pre_filing", "filed", "active", "closed"] },
        "summary": { "type": "string", "description": "One or two sentence plain-language summary of the matter." }
      }
    },
    "parties": {
      "type": "object",
      "description": "Named parties keyed by canonical role. Projects directly to downstream `parties`. Children use child_1, child_2, ... ",
      "additionalProperties": { "$ref": "#/$defs/party" },
      "properties": {
        "plaintiff": { "$ref": "#/$defs/party" },
        "defendant": { "$ref": "#/$defs/party" },
        "petitioner": { "$ref": "#/$defs/party" },
        "respondent": { "$ref": "#/$defs/party" },
        "client": { "$ref": "#/$defs/party", "description": "The represented client; usually aliases one of the role parties." },
        "decedent": { "$ref": "#/$defs/party" },
        "personal_representative": { "$ref": "#/$defs/party" },
        "attorney": { "$ref": "#/$defs/party" },
        "other_party": { "$ref": "#/$defs/party" }
      },
      "patternProperties": {
        "^child_[0-9]+$": { "$ref": "#/$defs/party" }
      }
    },
    "third_parties": {
      "type": "array",
      "description": "Non-party people and organizations relevant to the matter (witnesses, experts-as-people, institutions, agencies, beneficiaries, fiduciaries, employers).",
      "items": {
        "type": "object",
        "required": ["id", "name", "type"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "type": {
            "type": "string",
            "enum": [
              "witness", "expert", "opposing_counsel", "guardian_ad_litem", "financial_institution",
              "employer", "government_agency", "insurer", "beneficiary", "fiduciary", "creditor",
              "healthcare_provider", "business_entity", "neighbor", "family_member", "other"
            ]
          },
          "role": { "type": "string", "description": "Free-text role label for this matter." },
          "relationship": { "type": "string", "description": "Relationship to the client or matter." },
          "contact": { "$ref": "#/$defs/contact" },
          "description": { "type": "string" },
          "relevance": { "type": "string", "description": "Why this third party matters to the case." }
        }
      }
    },
    "fact_pattern": {
      "type": "object",
      "description": "The detailed story of the matter.",
      "required": ["summary", "narrative"],
      "additionalProperties": true,
      "properties": {
        "summary": { "type": "string" },
        "narrative": { "type": "string", "description": "Multi-paragraph factual narrative." },
        "undisputed_facts": { "type": "array", "items": { "type": "string" } },
        "disputed_facts": { "type": "array", "items": { "type": "string" } },
        "timeline": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["date", "event"],
            "additionalProperties": true,
            "properties": {
              "date": { "type": "string", "description": "ISO yyyy-mm-dd (approximate dates allowed)." },
              "event": { "type": "string" }
            }
          }
        }
      }
    },
    "intake_interview": {
      "type": "object",
      "description": "Simulated client intake interview as a sequence of exchanges.",
      "additionalProperties": true,
      "properties": {
        "interviewer": { "type": "string", "description": "e.g. 'Intake Attorney' or 'Paralegal'." },
        "interviewee_role": { "type": "string", "description": "Canonical role of the interviewee, e.g. 'plaintiff'." },
        "date": { "type": "string", "description": "ISO yyyy-mm-dd." },
        "exchanges": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["question", "answer"],
            "additionalProperties": true,
            "properties": {
              "topic": { "type": "string" },
              "question": { "type": "string" },
              "answer": { "type": "string" },
              "follow_up": { "type": "string" }
            }
          }
        }
      }
    },
    "client_objectives": {
      "type": "object",
      "description": "What the client needs, wants, and will not accept.",
      "additionalProperties": true,
      "properties": {
        "goals": { "type": "array", "items": { "type": "string" }, "description": "Ordered, highest priority first." },
        "priorities": { "type": "array", "items": { "type": "string" } },
        "constraints": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "budget": { "type": "string" },
            "timeline": { "type": "string" },
            "other": { "type": "string" }
          }
        },
        "risk_tolerance": { "type": "string", "enum": ["low", "moderate", "high"] },
        "desired_outcomes": { "type": "array", "items": { "type": "string" } },
        "non_starters": { "type": "array", "items": { "type": "string" }, "description": "Outcomes the client will not accept." }
      }
    },
    "issues": {
      "type": "array",
      "description": "Spotted legal issues, each tied to governing law where known.",
      "items": {
        "type": "object",
        "required": ["id", "issue"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string" },
          "issue": { "type": "string" },
          "category": { "type": "string" },
          "governing_law": { "type": "string", "description": "Statute/rule citation, e.g. '19-A M.R.S. s 1653'." },
          "sub_questions": { "type": "array", "items": { "type": "string" } },
          "client_position": { "type": "string" },
          "strength": { "type": "string", "enum": ["strong", "moderate", "weak", "unknown"] },
          "notes": { "type": "string" }
        }
      }
    },
    "expert_opinions": {
      "type": "array",
      "description": "Retained or anticipated expert opinions.",
      "items": {
        "type": "object",
        "required": ["id", "expert", "topic", "opinion"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string" },
          "expert": {
            "type": "object",
            "required": ["name", "field"],
            "additionalProperties": true,
            "properties": {
              "name": { "type": "string" },
              "field": { "type": "string" },
              "credentials": { "type": "string" },
              "retained_by": { "type": "string", "description": "Canonical role that retained the expert." }
            }
          },
          "topic": { "type": "string" },
          "opinion": { "type": "string" },
          "basis": { "type": "string", "description": "Methodology/materials relied upon." },
          "exhibits": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "evidence": {
      "type": "array",
      "description": "Documents and exhibits referenced by the matter.",
      "items": {
        "type": "object",
        "required": ["id", "title", "type"],
        "additionalProperties": true,
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["document", "photo", "financial_record", "correspondence", "contract", "medical_record", "public_record", "affidavit", "other"]
          },
          "description": { "type": "string" },
          "date": { "type": "string", "description": "ISO yyyy-mm-dd." },
          "source": { "type": "string" },
          "party": { "type": "string", "description": "Canonical role that controls/produced the item." }
        }
      }
    },
    "financials": {
      "type": "object",
      "description": "Monetary figures relevant to relief, valuation, or tax.",
      "additionalProperties": true,
      "properties": {
        "currency": { "type": "string", "default": "USD" },
        "amounts": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["label", "amount"],
            "additionalProperties": true,
            "properties": {
              "label": { "type": "string" },
              "amount": { "type": "number" },
              "basis": { "type": "string" }
            }
          }
        },
        "total_claimed": { "type": ["number", "null"] }
      }
    },
    "litigation": {
      "type": "object",
      "description": "Deep-litigation detail for contested matters: claims, defenses, discovery, motions, and docket. All optional.",
      "additionalProperties": true,
      "properties": {
        "posture": {
          "type": "string",
          "description": "Current procedural posture.",
          "enum": ["pre_suit", "pleadings", "discovery", "motion_practice", "pretrial", "trial", "post_trial", "appeal", "settlement"]
        },
        "causes_of_action": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["count", "claim"],
            "additionalProperties": true,
            "properties": {
              "count": { "type": ["integer", "string"], "description": "Count number, e.g. 1 or 'I'." },
              "claim": { "type": "string" },
              "by": { "type": "string", "description": "Claimant role." },
              "against": { "type": "string", "description": "Defending role." },
              "governing_law": { "type": "string" },
              "elements": { "type": "array", "items": { "type": "string" } },
              "relief_sought": { "type": "string" },
              "strength": { "type": "string", "enum": ["strong", "moderate", "weak", "unknown"] }
            }
          }
        },
        "affirmative_defenses": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["defense"],
            "additionalProperties": true,
            "properties": {
              "defense": { "type": "string" },
              "by": { "type": "string" },
              "basis": { "type": "string" }
            }
          }
        },
        "counterclaims": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "cross_claims": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "third_party_claims": { "type": "array", "items": { "type": "object", "additionalProperties": true } },
        "discovery": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["type"],
            "additionalProperties": true,
            "properties": {
              "type": {
                "type": "string",
                "enum": ["interrogatories", "request_for_production", "request_for_admission", "deposition", "subpoena", "expert_disclosure", "independent_examination"]
              },
              "propounding_party": { "type": "string" },
              "responding_party": { "type": "string" },
              "served_date": { "type": "string" },
              "due_date": { "type": "string" },
              "status": { "type": "string", "enum": ["served", "responded", "objected", "compelled", "outstanding"] },
              "description": { "type": "string" }
            }
          }
        },
        "motions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["title"],
            "additionalProperties": true,
            "properties": {
              "title": { "type": "string" },
              "type": { "type": "string" },
              "movant": { "type": "string" },
              "filed_date": { "type": "string" },
              "status": { "type": "string", "enum": ["filed", "opposed", "under_advisement", "granted", "denied", "granted_in_part", "withdrawn"] },
              "relief": { "type": "string" }
            }
          }
        },
        "docket": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["date", "entry"],
            "additionalProperties": true,
            "properties": {
              "date": { "type": "string" },
              "entry": { "type": "string" },
              "party": { "type": "string" }
            }
          }
        },
        "trial": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "jury": { "type": "boolean" },
            "estimated_days": { "type": ["integer", "number", "string"] },
            "scheduled_date": { "type": "string" }
          }
        }
      }
    },
    "facts": {
      "type": "object",
      "description": "Flat, form-specific canonical fact keys consumed by downstream form-fillers (passed through to canonical_case.facts unchanged). Values are scalars, arrays, or null.",
      "additionalProperties": true
    },
    "related_matters": {
      "type": "array",
      "description": "Links to sibling matters in the same compound matter universe.",
      "items": {
        "type": "object",
        "required": ["matter_id", "relationship"],
        "additionalProperties": true,
        "properties": {
          "universe_id": { "type": "string" },
          "matter_id": { "type": "string" },
          "scenario_id": { "type": "string" },
          "relationship": { "type": "string", "description": "How this matter relates to the linked one." },
          "description": { "type": "string" }
        }
      }
    },
    "notes": { "type": "string", "description": "Free-text generator or reviewer notes." }
  },
  "$defs": {
    "contact": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "address": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "zip": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" }
      }
    },
    "party": {
      "type": "object",
      "description": "A person or organization. Compatible with the downstream canonical party object. Provide full_name OR the first/middle/last components.",
      "additionalProperties": true,
      "properties": {
        "entity_type": { "type": "string", "enum": ["person", "organization"], "default": "person" },
        "full_name": { "type": "string" },
        "first_name": { "type": "string" },
        "middle_name": { "type": "string" },
        "last_name": { "type": "string" },
        "organization_name": { "type": "string" },
        "role": { "type": "string", "description": "Free-text role label." },
        "address": { "type": "string" },
        "city": { "type": "string" },
        "state": { "type": "string" },
        "zip": { "type": "string" },
        "phone": { "type": "string" },
        "email": { "type": "string" },
        "date_of_birth": { "type": "string", "description": "ISO yyyy-mm-dd." },
        "ssn_last4": { "type": "string", "description": "Fictional last 4 only; never a real SSN." },
        "signature": { "type": "string" },
        "bar_number": { "type": "string" },
        "description": { "type": "string" }
      }
    }
  }
}

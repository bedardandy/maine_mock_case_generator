{
  "form_id": "DE-301",
  "status": "authored-here",
  "source": "maine-probate-forms ships per-form field schemas (schema.json) but no canonical fact-key mapping. This mapping was authored in maine_mock_case_generator from the vendored schema.json field_ids/labels, so the probate repo can be driven by the same canonical case object as the court and tax repos. Review before production use.",
  "note": "field_id -> canonical fact-key. Court-use, register, and judge fields map to facts.court_use_* and are intentionally left unfilled by a party-side matter.",
  "map": {
    "county_probate_court": "matter.court_county",
    "docket_no": "matter.docket_number",
    "estate_of_decedent": "parties.decedent.full_name",
    "petitioner_name": "parties.personal_representative.full_name",
    "petitioner_contact": "parties.personal_representative.phone",
    "petitioner_interest": "facts.petitioner_interest",
    "petitioner_interest_other": "facts.petitioner_interest_other",
    "petitioner_interest_other_details": "facts.petitioner_interest_other_details",
    "decedent_full_legal_name": "parties.decedent.full_name",
    "date_of_death": "facts.date_of_death",
    "decedent_domicile": "facts.decedent_domicile_county",
    "domiciled_in_county": "facts.domiciled_in_county",
    "venue_basis_if_not_domiciled": "facts.venue_basis_if_not_domiciled",
    "person_whose_appointment_is_sought": "parties.personal_representative.full_name",
    "will_presented_for_probate": "facts.will_exists",
    "will_details": "facts.will_details",
    "nominated_as_pr_in_will": "facts.nominated_as_pr_in_will",
    "nomination_explanation": "facts.nomination_explanation",
    "reason_for_special_admin": "facts.reason_for_special_admin",
    "appointment_without_notice": "facts.appointment_without_notice",
    "emergency_nature": "facts.emergency_nature",
    "interested_party_name_1": "facts.interested_party_name_1",
    "interested_party_addr_1": "facts.interested_party_addr_1",
    "interested_party_name_2": "facts.interested_party_name_2",
    "interested_party_addr_2": "facts.interested_party_addr_2",
    "interested_party_name_3": "facts.interested_party_name_3",
    "interested_party_addr_3": "facts.interested_party_addr_3",
    "interested_party_name_4": "facts.interested_party_name_4",
    "interested_party_addr_4": "facts.interested_party_addr_4",
    "petitioner_signature": "party.signature",
    "date_signed": "today()",
    "attorney_name": "parties.attorney.full_name",
    "attorney_address": "parties.attorney.address",
    "attorney_phone": "parties.attorney.phone",
    "special_admin_acceptance_signature": "party.signature",
    "special_admin_acceptance_date": "today()",
    "order_limitations": "facts.order_limitations",
    "judge_date": "facts.court_use_judge_date",
    "judge_signature": "facts.court_use_judge_signature",
    "certified_copy_date": "facts.court_use_certified_copy_date",
    "register_signature": "facts.court_use_register_signature",
    "attorney_bar_number": "parties.attorney.bar_number",
    "attorney_email": "parties.attorney.email"
  },
  "facts": {
    "required": [
      "parties.decedent.full_name",
      "parties.personal_representative.full_name"
    ]
  }
}
